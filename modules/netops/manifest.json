{
  "id": "netops",
  "name": "NetOps Monitor",
  "version": "1.1.0",
  "description": "Real-time network monitoring with host scanning, port checking, latency measurement, and status change automation",
  "mainEntry": "main-handlers.js",
  "ipcChannels": [
    "netops:get-monitored-hosts",
    "netops:add-host",
    "netops:remove-host",
    "netops:ping-host",
    "netops:check-port",
    "netops:scan-network",
    "netops:get-status-history",
    "netops:get-host-detail",
    "netops:update-host-config",
    "netops:get-discovered-networks",
    "netops:get-discovered-hosts",
    "netops:remove-discovered-network",
    "netops:add-discovered-host",
    "netops:get-system-metrics",
    "netops:get-aggregate-metrics",
    "netops:get-recent-events",
    "netops:get-uptime-stats",
    "netops:get-heartbeat",
    "netops:export-data",
    "netops:import-data",
    "netops:backup-db",
    "netops:get-retention",
    "netops:set-retention",
    "netops:prune-data",
    "netops:status-update",
    "netops:status-change",
    "netops:scan-progress",
    "netops:get-alert-rules",
    "netops:add-alert-rule",
    "netops:update-alert-rule",
    "netops:delete-alert-rule",
    "netops:get-alerts",
    "netops:acknowledge-alert",
    "netops:get-active-alert-count",
    "netops:set-alert-settings",
    "netops:alert-triggered",
    "netops:alert-resolved",
    "netops:alert-navigate"
  ],
  "tabTypes": [
    { "id": "netops-dashboard", "label": "NetOps Monitor" }
  ],
  "rendererScripts": [
    "renderer/chart-config.js",
    "renderer/net-overview.js",
    "renderer/net-host-list.js",
    "renderer/net-host-detail.js",
    "renderer/net-discovery.js",
    "renderer/net-history.js",
    "renderer/net-alerts.js",
    "renderer/net-app.js"
  ],
  "rendererStyles": [
    "renderer/styles.css"
  ]
}
