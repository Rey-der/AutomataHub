{
  "name": "automata-hub",
  "productName": "AutomataHub",
  "version": "1.0.0",
  "description": "Modular Electron desktop hub for automation tools with plugin system",
  "main": "app/main.js",
  "author": "Rey-der",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rey-der/AutomataHub.git"
  },
  "homepage": "https://github.com/Rey-der/AutomataHub#readme",
  "keywords": [
    "electron",
    "automation",
    "script-runner",
    "modular",
    "plugins",
    "darwin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test tests/db-scanner.test.js tests/db-credentials.test.js",
    "rebuild-natives": "node-gyp rebuild --target=28.3.3 --arch=arm64 --dist-url=https://electronjs.org/headers --directory node_modules/better-sqlite3",
    "lint": "echo \"No lint configured yet\"",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.automatahub.app",
    "productName": "AutomataHub",
    "files": [
      "app/**",
      "renderer/**",
      "resources/**",
      "scripts/**",
      "modules/**",
      "logs/.gitkeep"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "AutomataHub"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AutomataHub"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chart.js": "^4.5.1",
    "sql.js": "^1.14.1",
    "uplot": "^1.6.32"
  }
}
